{
  "name": "@ph7/orbit",
  "version": "0.1.0",
  "description": "Orbit is a simple, efficient TypeScript web starter.",
  "type": "module",
  "author": "Pierre-Henry Soria <hi@ph7.me> (https://ph7.me)",
  "homepage": "https://github.com/pH-7/orbit#readme",
  "bugs": {
    "url": "https://github.com/pH-7/orbit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pH-7/orbit.git"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "orbit": "./dist/src/server.js"
  },
  "files": [
    "assets",
    "dist/src",
    "public",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm run build",
    "start": "pnpm run build && node dist/src/server.js",
    "test": "pnpm run build && node --test dist/test/*.test.js"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
