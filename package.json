{
  "name": "orbit",
  "version": "0.1.0",
  "description": "Orbit is a simple, efficient TypeScript web starter.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "pnpm run build && node dist/src/server.js",
    "test": "pnpm run build && node --test dist/test/*.test.js"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
